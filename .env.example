# ── Soteria Environment Variables ──
# Copy to .env and fill in values. Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────
# Secret key for JWT signing. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# ── Optional: GitHub OAuth (for /auth/github login) ───────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional: CVE Scraper (backend/scrape_cve.py) ─────────────────────────
# GitHub personal access token — 5000 req/hr vs 60 unauthenticated
GITHUB_TOKEN=

# NVD API key — raises NVD rate limit from 5/30s to 50/30s
NVD_API_KEY=

# ── Optional: Webhook integration ─────────────────────────────────────────
# Shared secret for Make.com / Zapier webhook endpoint validation
MAKE_WEBHOOK_SECRET=

# ── Optional: Gemini API (code explanation feature) ───────────────────────
GEMINI_API_KEY=

# ── Optional: Flask config ────────────────────────────────────────────────
# Set to "production" to enforce JWT_SECRET requirement and disable debug
FLASK_ENV=development

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Enable Swagger UI at /apidocs (set to "true" in dev only)
ENABLE_SWAGGER_UI=true
