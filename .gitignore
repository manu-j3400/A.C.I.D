# Ignore frontend modules
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.vercel/

# Ignore backend modules
backend/__pycache__/
backend/venv/
backend/.venv/
backend/*.pyc
__pycache__/
*.pyc

# Ignore environment variables
.env
.env*.local
frontend/.env
backend/.env

# OS / IDE junk
.DS_Store
*.log

# IDE / editor configs
.cursor/
.idea/

# Temporary generated files
tmp-antigravity-skills/

# Vercel CLI env file — contains OIDC tokens + Supabase keys, never commit
frontend/.env.vercel
.env.vercel

# Local databases — contain real user scan data, never commit
*.db
middleware/scan_history.db

# Automation task queue (runtime state)
automation_queue.json

# ML model backups (auto-created by retrain pipeline)
backend/ML_master/backups/

# Test artifacts
middleware/test_*.json
middleware/test_*.py
middleware/test_*.pdf

# Build artifacts
frontend/vite.config.d.ts
frontend/pnpm-lock.yaml
.vercel/
LOGO/
